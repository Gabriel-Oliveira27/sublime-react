generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────────────────────
// ENUMS
// ───────────────────────────────────────────

enum Linha {
  FREEZER
  AQUECER
  CONSERVAR
  PREPARAR
  SERVIR
  ARMAZENAR
}

enum MetodoPagamento {
  DINHEIRO
  PIX
  CREDITO
}

enum StatusPagamento {
  PENDENTE
  REALIZADO
}

enum EtapaPedido {
  RESERVADO
  CONFIRMADO
  EM_PREPARO
  SAIU_PARA_ENTREGA
  ENTREGUE
  CANCELADO
}

// ───────────────────────────────────────────
// MODELS
// ───────────────────────────────────────────

model Estoque {
  id      Int     @id @default(autoincrement())
  qtd     Int
  produto String
  cores   String
  litros  String
  valor   Decimal @db.Decimal(10, 2)
  linha   Linha
  imagem  String
  filtros String
}

model Cupom {
  id             Int     @id @default(autoincrement())
  cupom          String  @unique
  desconto       String
  quantidadeUsos Int     @default(0)
}

model Pedido {
  id              Int             @id @default(autoincrement())
  idRastreio      String          @unique
  nome            String
  contato         String
  cpf             String?
  pedido          Json
  endereco        String
  totalVenda      Decimal         @db.Decimal(10, 2)
  metodoPagamento MetodoPagamento
  pagamento       StatusPagamento @default(PENDENTE)
  etapa           EtapaPedido     @default(RESERVADO)
  cupom           String?
  frete           Decimal         @db.Decimal(10, 2) @default(0)
  dataCompra      DateTime        @default(now())
  parcelas        Int             @default(1)
  trocoPara       Decimal?        @db.Decimal(10, 2)
  valorALevar     Decimal?        @db.Decimal(10, 2)
}

model Cliente {
  id      Int      @id @default(autoincrement())
  nome    String
  cpf     String   @unique
  compras String[]
  contato String
}

model Usuario {
  id      Int     @id @default(autoincrement())
  nome    String
  apelido String
  email   String  @unique
  senha   String
  ativo   Boolean @default(true)
}

model Config {
  chave String @id
  valor String
}