// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Linha {
  FREEZER
  AQUECER
  CONSERVAR
  PREPARAR
  SERVIR
  ARMAZENAR
}

enum MetodoPagamento {
  DINHEIRO
  PIX
  CREDITO
}

enum StatusPagamento {
  PENDENTE
  REALIZADO
}

enum EtapaPedido {
  RESERVADO
  CONFIRMADO
  EM_PREPARO
  SAIU_PARA_ENTREGA
  ENTREGUE
  CANCELADO
}

model Estoque {
  id       Int     @id @default(autoincrement())
  qtd      Int
  produto  String
  cores    String
  litros   String
  valor    Decimal @db.Decimal(10, 2)
  linha    Linha
  imagem   String
  filtros  String  @default("")
  detalhes String?
}

model Cupom {
  id             Int    @id @default(autoincrement())
  cupom          String @unique
  desconto       String
  quantidadeUsos Int    @default(0)
}

model Pedido {
  id              Int             @id @default(autoincrement())
  idRastreio      String          @unique
  nome            String
  contato         String
  pedido          Json
  endereco        String
  totalVenda      Decimal         @db.Decimal(10, 2)
  subtotal        Decimal         @db.Decimal(10, 2) @default(0)
  metodoPagamento MetodoPagamento
  pagamento       StatusPagamento @default(PENDENTE)
  etapa           EtapaPedido     @default(RESERVADO)
  cupom           String?
  frete           Decimal         @db.Decimal(10, 2) @default(0)
  dataCompra      DateTime        @default(now())
  parcelas        Int             @default(1)
  trocoPara       Decimal?        @db.Decimal(10, 2)
  valorALevar     Decimal?        @db.Decimal(10, 2)
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nome      String
  cpf       String   @unique
  compras   String[]
  contato   String
  enderecos String[] @default([])
}

model Usuario {
  id         Int      @id @default(autoincrement())
  nome       String
  apelido    String
  email      String   @unique
  senha      String
  ativo      Boolean  @default(true)
  isAdmin    Boolean  @default(false)
  permissoes Json?
  foto       String?
  tema       String   @default("dark")
  criadoEm  DateTime @default(now())
}

model Config {
  chave String @id
  valor String
}

// ── Configuração de Frete (singleton — sempre id = 1) ────────────────────────
//
// modelo: "VALOR" | "KM" | "FIXO" | "CIDADE"
//
// VALOR  → tiersValor: [{ ate: number|null, taxa: number }]
//          ate = valor máximo do carrinho para aplicar a taxa; null = sem limite (última faixa)
//
// KM     → custoKm, freteGratisAteKm + origem (lat/lon/endereço)
//
// FIXO   → valorFixo
//
// CIDADE → valorCidadeOrigem, valorDemais, cidadesEspeciais (lista extra) + origem (endereço)
//          cidadesEspeciais: [{ nome: string, valor: number }]
//
model FreteConfig {
  id    Int    @id @default(autoincrement())

  modelo String @default("VALOR")

  // ── VALOR ──────────────────────────────────────────────────────────────────
  tiersValor Json?

  // ── KM e CIDADE — origem compartilhada ────────────────────────────────────
  origemLat      Float?
  origemLon      Float?
  origemEndereco String @default("")
  origemCep      String @default("")
  origemCidade   String @default("")
  origemUF       String @default("")

  // ── KM ────────────────────────────────────────────────────────────────────
  custoKm          Float @default(1.50)
  freteGratisAteKm Float @default(0)

  // ── FIXO ──────────────────────────────────────────────────────────────────
  valorFixo Float @default(0)

  // ── CIDADE ────────────────────────────────────────────────────────────────
  valorCidadeOrigem Float @default(0)
  valorDemais       Float @default(0)
  cidadesEspeciais  Json?

  atualizadoEm DateTime @updatedAt
}
